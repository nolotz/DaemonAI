# ─── AWS (deploy & local development) ─────────────────────────────────────────
# Credentials come from the AWS profile / SSO — never put keys in files.
AWS_REGION=eu-central-1
AWS_PROFILE=daemonai

# The CDK stage is selected via context: npm run deploy:dev / deploy:prod

# ─── Backend (local dev server: backend/.env) ─────────────────────────────────
TABLE_NAME=daemonai-dev
AUDIO_BUCKET=daemonai-audio-dev
USER_POOL_ID=eu-central-1_xxxxxxxxx
USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-5-20250929-v1:0
# German neural voices: Vicki (default) or Daniel
POLLY_VOICE_ID=Vicki
STAGE=dev

# ─── Frontend (frontend/.env.local) ───────────────────────────────────────────
# Values appear in the CloudFormation outputs of the Api/Auth stacks after deploy.
VITE_API_URL=https://xxxxxxxxxx.execute-api.eu-central-1.amazonaws.com
VITE_CHAT_URL=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.lambda-url.eu-central-1.on.aws
VITE_USER_POOL_ID=eu-central-1_xxxxxxxxx
VITE_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
